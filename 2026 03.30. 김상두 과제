        "A = df_year.iloc[-1][\"근속연수\"]\n",
        "\n",
        "df[\"연봉_만족도\"] = df[\"연봉\"] / df[\"만족도\"]\n",
        "df_like = df.nlargest(2, '연봉_만족도')\n",
        "B = df_like.iloc[-1][\"교육참가횟수\"]\n",
