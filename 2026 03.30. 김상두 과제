        "\n",
        "\n",
        "idx = df_pivot.groupby(\"연도\")[\"검거율\"].idxmax()\n",
        "max_crime = df_pivot.loc[idx]\n",
        "\n",
        "\n",
        "result = max_crime[\"검거건수\"].sum()\n",
        "print(result)"
